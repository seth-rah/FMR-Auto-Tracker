                    </Border>
                    <Border Grid.Row="2" Grid.Column="5" x:Name="AtkCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="AtkRange5" Text="20+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="AtkScore5" Text="-4" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Defensive Wins" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="3" Grid.Column="1" x:Name="DefWinsCell1" Background="#2a2a3a" Padding="4" Margin="1">
