                            <TextBlock x:Name="MagicScore2" Text="-4" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="7" Grid.Column="3" x:Name="MagicCell3" Background="#2a2a3a" Padding="4" Margin="1">
