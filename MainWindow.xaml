                            <TextBlock x:Name="TrapScore2" Text="-8" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="8" Grid.Column="3" x:Name="TrapCell3" Background="#2a2a3a" Padding="4" Margin="1">
