                            <TextBlock x:Name="DefWinsRange1" Text="0-1" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="DefWinsScore1" Text="+0" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
