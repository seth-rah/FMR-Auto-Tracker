                            <TextBlock x:Name="AtkRange3" Text="4-9" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="AtkScore3" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
