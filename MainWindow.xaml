                        <StackPanel>
                            <TextBlock x:Name="MagicRange1" Text="0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="MagicScore1" Text="+2" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
