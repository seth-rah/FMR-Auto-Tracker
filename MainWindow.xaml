                        </StackPanel>
                    </Border>
                    <Border Grid.Row="8" Grid.Column="5" x:Name="TrapCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="TrapRange5" Text="7+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TrapScore5" Text="-32" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Remaining LP" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="9" Grid.Column="1" x:Name="LPCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="LPRange1" Text="8000+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="LPScore1" Text="+6" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="9" Grid.Column="2" x:Name="LPCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="LPRange2" Text="7000-7999" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="LPScore2" Text="+4" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="9" Grid.Column="3" x:Name="LPCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="LPRange3" Text="1000-6999" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="LPScore3" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="9" Grid.Column="4" x:Name="LPCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="LPRange4" Text="100-999" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="LPScore4" Text="-5" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="9" Grid.Column="5" x:Name="LPCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="LPRange5" Text="0-99" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="LPScore5" Text="-7" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock x:Name="StatusText" Text="Status: Not Attached" Foreground="#00BCD4" FontSize="14"/>
            <Expander x:Name="DebugExpander" Header="Debug Log" Foreground="#FFC107" Margin="0,10,0,0" Visibility="Collapsed">
                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DebugLogText" Text="" Foreground="#00FF00" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Expander>
        </StackPanel>
    </Grid>
</Window>