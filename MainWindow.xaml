<Window x:Class="YuGiOh_Forbidden_Memories_Monitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yu-Gi-Oh! Forbidden Memories Monitor"
        Height="900" Width="800"
        MinHeight="600" MinWidth="700"
        Background="#1E1E2E"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Annihilation" Foreground="#00BCD4" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Game ID" Foreground="#FFC107" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="GameIdText" Text="[Not attached]" Foreground="#00FF00" FontFamily="Consolas" FontSize="14"/>
                </StackPanel>
            </Grid>
            
            <TextBlock Text="Life Points" Foreground="#FFC107" FontSize="13" FontWeight="Bold" Margin="0,15,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Player 1" Foreground="#FFC107" FontSize="13" FontWeight="Bold"/>
                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="2" Background="#444466" Margin="15,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Player 2" Foreground="#FFC107" FontSize="13" FontWeight="Bold" Margin="15,0,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="P1LifePointsText" Text="0" Foreground="#00FF00" FontSize="28" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="P2LifePointsText" Text="0" Foreground="#FF6666" FontSize="28" FontWeight="Bold" Margin="15,0,0,0"/>
            </Grid>
                
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Score" Foreground="#FFC107" FontSize="13" FontWeight="Bold"/>
                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="2" Background="#444466" Margin="15,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Starchips:" Foreground="#FFC107" FontSize="13" FontWeight="Bold" Margin="15,0,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="DuelScoreText" Text="0 = --" Foreground="#00FF00" FontSize="28" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="StarchipsText" Text="0" Foreground="#00FF00" FontSize="28" FontWeight="Bold" Margin="15,0,0,0"/>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top" MaxHeight="250">
            <Button x:Name="AttachDetachButton" Content="Attach" Width="120" Height="40" Click="AttachDetachButton_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="Using this tool is not&#x0a;allowed when speedrunning" Foreground="#FF6666" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
            <TextBlock Text="Duel Stats" Foreground="#FFC107" FontSize="13" FontWeight="Bold" Margin="0,15,0,10"/>
            <Border Background="#2a2a3a" Padding="6" BorderBrush="#444466" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cards Used" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="0" Grid.Column="1" x:Name="CardsUsedCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="CardsUsedRange1" Text="0-8" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="CardsUsedScore1" Text="+15" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" x:Name="CardsUsedCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="CardsUsedRange2" Text="9-12" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="CardsUsedScore2" Text="+12" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="3" x:Name="CardsUsedCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="CardsUsedRange3" Text="13-32" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="CardsUsedScore3" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="4" x:Name="CardsUsedCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="CardsUsedRange4" Text="33-36" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="CardsUsedScore4" Text="-5" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="5" x:Name="CardsUsedCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="CardsUsedRange5" Text="37+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="CardsUsedScore5" Text="-7" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Duel Turns" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="1" Grid.Column="1" x:Name="TurnsCell1" Background="#2a2a3a" Padding="4" Margin="1">
