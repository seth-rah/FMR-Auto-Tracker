                    </Border>
                    <Border Grid.Row="7" Grid.Column="5" x:Name="MagicCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="MagicRange5" Text="10+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="MagicScore5" Text="-16" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Trigger Trap" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="8" Grid.Column="1" x:Name="TrapCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="TrapRange1" Text="0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TrapScore1" Text="+2" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="8" Grid.Column="2" x:Name="TrapCell2" Background="#2a2a3a" Padding="4" Margin="1">
