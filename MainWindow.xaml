                            <TextBlock x:Name="EquipScore2" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="3" x:Name="EquipCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="EquipRange3" Text="5-9" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="EquipScore3" Text="-4" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="4" x:Name="EquipCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="EquipRange4" Text="10-14" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="EquipScore4" Text="-8" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="5" x:Name="EquipCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="EquipRange5" Text="15+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="EquipScore5" Text="-12" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Pure Magic" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
