                            <TextBlock x:Name="DefWinsRange2" Text="2-5" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="DefWinsScore2" Text="-10" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="3" x:Name="DefWinsCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="DefWinsRange3" Text="6-9" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="DefWinsScore3" Text="-20" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="4" x:Name="DefWinsCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="DefWinsRange4" Text="10-14" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="DefWinsScore4" Text="-30" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="5" x:Name="DefWinsCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="DefWinsRange5" Text="15+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="DefWinsScore5" Text="-40" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Face-Down" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="4" Grid.Column="1" x:Name="FaceDownCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FaceDownRange1" Text="0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FaceDownScore1" Text="+0" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="2" x:Name="FaceDownCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FaceDownRange2" Text="1-10" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FaceDownScore2" Text="-2" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="3" x:Name="FaceDownCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FaceDownRange3" Text="11-20" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FaceDownScore3" Text="-4" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="4" x:Name="FaceDownCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FaceDownRange4" Text="21-30" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FaceDownScore4" Text="-6" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="5" x:Name="FaceDownCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FaceDownRange5" Text="31+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FaceDownScore5" Text="-8" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Fusion" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="5" Grid.Column="1" x:Name="FusionCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FusionRange1" Text="0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FusionScore1" Text="+4" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="2" x:Name="FusionCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FusionRange2" Text="1-4" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FusionScore2" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="3" x:Name="FusionCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FusionRange3" Text="5-9" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FusionScore3" Text="-4" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="4" x:Name="FusionCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FusionRange4" Text="10-14" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FusionScore4" Text="-8" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="5" x:Name="FusionCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="FusionRange5" Text="15+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="FusionScore5" Text="-12" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Equip Magic" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
