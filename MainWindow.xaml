                    </Border>
                    <Border Grid.Row="7" Grid.Column="4" x:Name="MagicCell4" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="MagicRange4" Text="7-9" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="MagicScore4" Text="-12" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
