                            <TextBlock x:Name="TurnsRange4" Text="29-32" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TurnsScore4" Text="-8" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="5" x:Name="TurnsCell5" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="TurnsRange5" Text="33+" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TurnsScore5" Text="-12" Foreground="#FF6666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Effective Atk" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Row="2" Grid.Column="1" x:Name="AtkCell1" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="AtkRange1" Text="0-1" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="AtkScore1" Text="+4" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" x:Name="AtkCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="AtkRange2" Text="2-3" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="AtkScore2" Text="+2" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="3" x:Name="AtkCell3" Background="#2a2a3a" Padding="4" Margin="1">
