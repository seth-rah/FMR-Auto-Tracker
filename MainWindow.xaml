                            <TextBlock x:Name="TurnsRange1" Text="0-4" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TurnsScore1" Text="+12" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" x:Name="TurnsCell2" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="TurnsRange2" Text="5-8" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TurnsScore2" Text="+8" Foreground="#00FF00" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="3" x:Name="TurnsCell3" Background="#2a2a3a" Padding="4" Margin="1">
                        <StackPanel>
                            <TextBlock x:Name="TurnsRange3" Text="9-28" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                            <TextBlock x:Name="TurnsScore3" Text="+0" Foreground="#666666" FontSize="13" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="4" x:Name="TurnsCell4" Background="#2a2a3a" Padding="4" Margin="1">
